# Google Gemini API Key (for AI-powered product descriptions and RAG responses)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone API Key (for vector/semantic product search)
# Get yours at: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone Index Name (default: ecommers)
PINECONE_INDEX_NAME=ecommers

# PostgreSQL Database URL (leave empty to use SQLite fallback for local dev)
# Example: postgresql://user:password@localhost:5432/ecommers
DATABASE_URL=
